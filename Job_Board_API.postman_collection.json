{
    "info": {
        "name": "Job Board API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8001/api"
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "admin_token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "1. Auth",
            "item": [
                {
                    "name": "Register Candidate",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\":\"candidate1\",\"email\":\"cand@test.com\",\"password\":\"pass123\",\"role\":\"candidate\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/register/"
                        }
                    }
                },
                {
                    "name": "Register Employer",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\":\"employer1\",\"email\":\"emp@test.com\",\"password\":\"pass123\",\"role\":\"employer\",\"company\":\"Tech Corp\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/register/"
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\":\"candidate1\",\"password\":\"pass123\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login/"
                        },
                        "script": {
                            "type": "text/javascript",
                            "exec": [
                                "let json = JSON.parse(responseBody);",
                                "postman.setEnvironmentVariable(\"token\", json.access);"
                            ]
                        }
                    }
                },
                {
                    "name": "My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/auth/profile/"
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Jobs",
            "item": [
                {
                    "name": "List Jobs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/"
                        }
                    }
                },
                {
                    "name": "Create Job (Employer)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"title\":\"Python Developer\",\"description\":\"Build APIs\",\"requirements\":\"Python, Django\",\"location\":\"Remote\",\"employment_type\":\"full\",\"salary_min\":80000,\"salary_max\":120000,\"expires_at\":\"2025-12-31\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/"
                        }
                    }
                },
                {
                    "name": "Job Details",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/1/"
                        }
                    }
                },
                {
                    "name": "Update Job",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"salary_max\":150000}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/1/"
                        }
                    }
                },
                {
                    "name": "Search Jobs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/?search=python&location=remote"
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Applications",
            "item": [
                {
                    "name": "Apply to Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "cover_letter",
                                    "value": "I am interested",
                                    "type": "text"
                                },
                                {
                                    "key": "resume",
                                    "value": "",
                                    "type": "file",
                                    "src": "C:/resume.txt"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/1/apply/"
                        }
                    }
                },
                {
                    "name": "My Applications",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/jobs/applications/my/"
                        }
                    }
                },
                {
                    "name": "Employer Applications",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/jobs/applications/employer/"
                        }
                    }
                },
                {
                    "name": "Update Status",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"status\":\"reviewed\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/applications/1/status/"
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Saved Jobs",
            "item": [
                {
                    "name": "Save Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"job_id\":1}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/saved/"
                        }
                    }
                },
                {
                    "name": "List Saved",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/jobs/saved/"
                        }
                    }
                }
            ]
        },
        {
            "name": "5. Company Reviews",
            "item": [
                {
                    "name": "Post Review",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"rating\":5,\"comment\":\"Great company!\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/companies/1/reviews/"
                        }
                    }
                },
                {
                    "name": "Get Reviews",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/companies/1/reviews/"
                        }
                    }
                }
            ]
        },
        {
            "name": "6. Notifications",
            "item": [
                {
                    "name": "Email Preferences",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/jobs/email-preferences/"
                        }
                    }
                },
                {
                    "name": "Update Email Prefs",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"receive_email_notifications\":false}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/email-preferences/"
                        }
                    }
                },
                {
                    "name": "Job Alerts",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"search_keyword\":\"Python\",\"location\":\"Remote\",\"frequency\":\"daily\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/alerts/"
                        }
                    }
                }
            ]
        },
        {
            "name": "7. Analytics",
            "item": [
                {
                    "name": "Employer Stats",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/jobs/my/stats/"
                        }
                    }
                },
                {
                    "name": "Rating Summary",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/companies/1/reviews/summary/"
                        }
                    }
                },
                {
                    "name": "Job Share Links",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/1/share/"
                        }
                    }
                }
            ]
        },
        {
            "name": "8. Health Check",
            "item": [
                {
                    "name": "API Health",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/"
                        }
                    }
                },
                {
                    "name": "Redis Health",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/stats/"
                        }
                    }
                }
            ]
        },
        {
            "name": "9. Admin",
            "item": [
                {
                    "name": "Admin Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\":\"admin\",\"password\":\"admin123\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login/"
                        },
                        "script": {
                            "type": "text/javascript",
                            "exec": [
                                "let json = JSON.parse(responseBody);",
                                "postman.setEnvironmentVariable(\"admin_token\", json.access);"
                            ]
                        }
                    }
                },
                {
                    "name": "Dashboard Stats",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/stats/"
                        }
                    }
                },
                {
                    "name": "Recent Jobs",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/recent-jobs/"
                        }
                    }
                },
                {
                    "name": "Recent Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/recent-users/"
                        }
                    }
                },
                {
                    "name": "Flag Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/jobs/1/flag/"
                        }
                    }
                }
            ]
        },
        {
            "name": "10. Rate Limit Testing",
            "item": [
                {
                    "name": "Test Apply Limit (5/hour)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "cover_letter",
                                    "value": "Test",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/jobs/1/apply/"
                        }
                    }
                },
                {
                    "name": "Test Anonymous Limit (100/day)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/jobs/"
                        }
                    }
                }
            ]
        }
    ]
}